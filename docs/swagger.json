{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/health": {
            "get": {
                "description": "Returns service health and runtime information",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.HealthResponse"
                        }
                    }
                }
            }
        },
        "/session/create": {
            "post": {
                "description": "Creates a new session with the given TTL and session timeout",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "session"
                ],
                "summary": "Create a new session",
                "parameters": [
                    {
                        "description": "Session create payload",
                        "name": "session",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.SessionCreateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.SessionCreateResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/session/terminate": {
            "post": {
                "description": "Terminates an active session by its token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "session"
                ],
                "summary": "Terminate a session",
                "parameters": [
                    {
                        "description": "Session terminate payload",
                        "name": "session",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.SessionTerminateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "successfully terminated session.",
                        "schema": {
                            "$ref": "#/definitions/api.SessionTerminateResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/session/update": {
            "post": {
                "description": "Updates the location information (longitude \u0026 latitude) of an active session identified by its token.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "session"
                ],
                "summary": "Update a session",
                "parameters": [
                    {
                        "description": "Session update payload",
                        "name": "session",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.SessionUpdateRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Session updated.",
                        "schema": {
                            "$ref": "#/definitions/api.SessionUpdateResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/session/{token}": {
            "get": {
                "description": "Fetches the current longitude, latitude and last‑update timestamp for a session identified by its token.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "session"
                ],
                "summary": "Retrieve a session",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Session token",
                        "name": "token",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Session retrieved.",
                        "schema": {
                            "$ref": "#/definitions/api.SessionGetResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "invalid json"
                }
            }
        },
        "api.HealthResponse": {
            "type": "object",
            "properties": {
                "runtime": {
                    "type": "string",
                    "example": "38271.133967079s"
                },
                "status": {
                    "type": "string",
                    "example": "OK"
                }
            }
        },
        "api.SessionCreateRequest": {
            "type": "object",
            "properties": {
                "session_timeout": {
                    "type": "integer",
                    "example": 7200
                },
                "ttl": {
                    "type": "integer",
                    "example": 3600
                }
            }
        },
        "api.SessionCreateResponse": {
            "type": "object",
            "properties": {
                "parameters": {
                    "$ref": "#/definitions/api.SessionCreateRequest"
                },
                "token": {
                    "type": "string",
                    "example": "3A9N2O"
                }
            }
        },
        "api.SessionGetResponse": {
            "type": "object",
            "properties": {
                "last_update": {
                    "type": "string",
                    "example": "2026-03-01T13:23:45.206365244+01:00"
                },
                "latitude": {
                    "type": "number",
                    "example": 8.385259
                },
                "longitude": {
                    "type": "number",
                    "example": 49.026598
                },
                "token": {
                    "type": "string",
                    "example": "3A9N2O"
                }
            }
        },
        "api.SessionTerminateRequest": {
            "type": "object",
            "properties": {
                "token": {
                    "type": "string",
                    "example": "3A9N2O"
                }
            }
        },
        "api.SessionTerminateResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "successfully terminated session."
                },
                "token": {
                    "type": "string",
                    "example": "3A9N2O"
                }
            }
        },
        "api.SessionUpdateRequest": {
            "type": "object",
            "properties": {
                "latitude": {
                    "type": "number",
                    "example": 8.385259
                },
                "longitude": {
                    "type": "number",
                    "example": 49.026598
                },
                "token": {
                    "type": "string",
                    "example": "3A9N2O"
                }
            }
        },
        "api.SessionUpdateResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "successfully updated session."
                },
                "token": {
                    "type": "string",
                    "example": "3A9N2O"
                }
            }
        }
    }
}